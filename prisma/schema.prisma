generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model TaskAd {
  id       Int      @id @default(autoincrement())
  name     String
  detail   String?
  schedule DateTime
  tasks    Task[]
}

model Task {
  id       Int      @id @default(autoincrement())
  taskAdId Int
  name     String
  wage     Float
  detail   String?
  taskAd   TaskAd   @relation(fields: [taskAdId], references: [id], onDelete: Cascade)
}